	position: relative;
}

.main-form .elementor-field-group:before{
	content: '';
	background: linear-gradient(83deg, #52d8ea 7%, #916aff 80%);
	position: absolute;
	top: 0;
	left: 0;
	z-index: -1;
	bottom: -1px;
	left: 4px;
	top: -1px;
	right: 4px;
	border-radius: 5px;
	opacity: 0;
	transition: 300ms ease;
}

.main-form .elementor-field-group:not(.elementor-field-type-acceptance):has(input:focus):before,
.main-form .elementor-field-group:has(textarea:focus):before{
	opacity: 1 !important;
}

.main-form input:focus,
.main-form textarea:focus{
	border: transparent 1px solid !important;
	outline: none !important;
	box-shadow: none !important;
}

body:has(.dark-hero) .nav-logo{
	filter: brightness(0) invert(1);
}

@media screen and (max-width: 1024px) {
	body:has(.dark-hero) .nav-logo{
	filter: none;
}
}

body:has(.marketing-hero) .nav-logo {
	filter: brightness(0) invert(1);
}

body:has(.marketing-hero) .elementor-location-header .menu-item .elementor-item,
body:has(.marketing-hero) .elementor-location-header .elementor-button-link {
	color: #FFF!important;
}


body:has(.marketing-hero) .elementor-location-header .elementor-button-link {
	background-color: transparent!important;
}

body:has(.marketing-hero) .elementor-location-header .elementor-button-link:hover {
	background-color: #916aff!important;
	color: #d9d4ff!important;
